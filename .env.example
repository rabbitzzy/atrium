# Copy to .env and fill in values. Never commit .env.
ANTHROPIC_API_KEY=sk-ant-...

# Illustration generation (tools/illustrate.ts)
# Provider is chosen automatically: FAL_KEY wins over HF_TOKEN if both are set.
# Override with: PROVIDER=hf or PROVIDER=fal
HF_TOKEN=hf_...
FAL_KEY=...

# Supabase (from project settings → API)
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Service ports (defaults shown)
SKILL_GRAPH_PORT=3001
WORKSHEET_PORT=3002
EVALUATOR_PORT=3003
